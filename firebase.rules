rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Para produção, substitua por request.auth.token.admin == true.
    function isAdmin() {
      return signedIn()
        && request.auth.token.email == 'gustavoitalo1224@gmail.com';
    }

    match /games/{gameId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /bets/{betId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll([
        'gameId', 'name', 'phone', 'environment', 'homeScore', 'awayScore', 'paymentStatus'
      ])
      && request.resource.data.paymentStatus == 'pending';
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
